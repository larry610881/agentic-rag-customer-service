# === Cloud Run Backend 環境變數 ===
# 複製此檔為實際使用，填入真實值

# --- Database (VM PostgreSQL via IAP / VPC Connector) ---
DATABASE_URL_OVERRIDE=postgresql+asyncpg://postgres:postgres@<VM_INTERNAL_IP>:5432/agentic_rag

# --- Redis (VM) ---
REDIS_URL_OVERRIDE=redis://<VM_INTERNAL_IP>:6379/0

# --- Milvus (VM) ---
MILVUS_URI=http://<VM_INTERNAL_IP>:19530

# --- Storage ---
STORAGE_BACKEND=gcs
GCS_BUCKET_NAME=agentic-rag-cs-documents

# --- JWT ---
JWT_SECRET_KEY=<GENERATE_A_STRONG_SECRET>
JWT_ALGORITHM=HS256

# --- LLM ---
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=<YOUR_KEY>
OPENAI_API_KEY=<YOUR_KEY>

# --- Embedding ---
EMBEDDING_PROVIDER=openai

# --- CORS ---
CORS_ORIGINS=https://your-frontend.pages.dev,https://your-domain.com

# --- LINE Bot ---
LINE_CHANNEL_SECRET=<YOUR_SECRET>
LINE_CHANNEL_ACCESS_TOKEN=<YOUR_TOKEN>

# --- App ---
APP_ENV=production
LOG_LEVEL=INFO
ENABLED_MODULES=api,websocket,webhook
